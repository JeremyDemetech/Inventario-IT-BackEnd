# Ejemplo de variables de entorno para SQL Server
DB_HOST=localhost
DB_PORT=1433
DB_USER=IT
DB_PASSWORD=123
DB_NAME=Test

# Puerto de la API
PORT=3000

# Alternativa: cadena de conexión completa (si prefieres usar una sola variable)
# DB_CONNECTION_STRING=Server=localhost,1433;Database=InventarioDB;User Id=sa;Password=Your_password123;Encrypt=false;TrustServerCertificate=true

# Rutas a certificados para HTTPS (opcional para desarrollo)
# Ruta al archivo .key (clave privada)
# SSL_KEY_PATH=./certs/server.key
# Ruta al archivo .crt o .pem (certificado)
# SSL_CERT_PATH=./certs/server.crt

# JWT
# Secret para firmar tokens (cambiar en producción)
# JWT_SECRET=tu_secreto_jwt_aqui
# Tiempo de expiración (ej: 1h, 7d)
# JWT_EXPIRES_IN=1h
